# Muquirana - variaveis de producao (painel do Coolify)
#
# Cole no painel do Coolify. Use com docker/docker-compose.production.yml.
#
# Se quiser guardar os valores reais em disco, copie para
# docker/.env.production (gitignored) -- NAO para um .env na raiz do projeto.
# O dotenv-rails carrega .env automaticamente em TODOS os ambientes, entao um
# .env com valores de producao na raiz vaza POSTGRES_DB=muquirana_production
# para o ambiente de teste e quebra `bin/rails test` com
# "We could not find your database: muquirana_production".
#
# ---------------------------------------------------------------------------
# OBRIGATORIAS - o app nao sobe (ou sobe quebrado) sem elas
# ---------------------------------------------------------------------------

# Host canonico, SEM https:// e sem barra final. Ex: muquirana.com
#
# Usado em dois lugares:
#   1. regra de Host do Traefik (docker-compose.production.yml)
#   2. links dos e-mails (reset de senha, convite) --
#      config.action_mailer.default_url_options em config/environments/production.rb
# Sem isto, o e-mail de reset de senha sai com link quebrado.
APP_DOMAIN=

# openssl rand -hex 64
#
# NUNCA reaproveite o valor de exemplo do compose.example.yml -- ele e publico.
# Em modo self-hosted este segredo deriva as chaves de criptografia do banco:
# quem o obtiver le os tokens de acesso bancario e as chaves de API.
SECRET_KEY_BASE=

# openssl rand -base64 32
POSTGRES_PASSWORD=

# openssl rand -hex 32
#
# HEX, nao base64. Esta senha entra dentro de uma URL
# (REDIS_URL=redis://default:SENHA@muquirana-redis:6379/0), e o alfabeto do base64
# "/" e "+": um "/" corta a URL e o parser le o resto como porta --
# "Port could not be cast to integer". Hex e URL-safe por definicao.
REDIS_PASSWORD=

# ---------------------------------------------------------------------------
# BANCO - os defaults servem; mude so se precisar
# ---------------------------------------------------------------------------
POSTGRES_DB=muquirana_production
POSTGRES_USER=muquirana

# ---------------------------------------------------------------------------
# IMAGEM
# ---------------------------------------------------------------------------
# Publicada por .github/workflows/publish.yml em push na main e em tag v*.
# Para fixar uma release: ghcr.io/bulletdev/muquirana:v0.7.0
MUQUIRANA_IMAGE=ghcr.io/bulletdev/muquirana:latest

# ---------------------------------------------------------------------------
# TLS - deixe ambos em true atras do Traefik
# ---------------------------------------------------------------------------
# ASSUME_SSL faz o Rails confiar no X-Forwarded-Proto do proxy. Sem ele, o
# force_ssl acha que a conexao e HTTP e redireciona em loop infinito.
#
# No Cloudflare, use SSL "Full (strict)". Em "Flexible" o Cloudflare fala HTTP
# com a origem, o Rails redireciona pra HTTPS, o Cloudflare volta em HTTP --
# loop de redirect. Esse e o erro classico deste setup.
RAILS_FORCE_SSL=true
RAILS_ASSUME_SSL=true

# ---------------------------------------------------------------------------
# PERFORMANCE
# ---------------------------------------------------------------------------
WEB_CONCURRENCY=2
RAILS_MAX_THREADS=5

# ---------------------------------------------------------------------------
# CODIGO-FONTE E RELEASES
# ---------------------------------------------------------------------------
# AGPLv3 secao 13: quem usa o app pela rede tem direito ao codigo-fonte desta
# instancia. O rodape linka este endereco. Se voce modificar o app, aponte para
# o SEU fork -- e obrigacao da licenca, nao cortesia.
SOURCE_CODE_URL=https://github.com/Bulletdev/muquirana

# Alimentam a tela "Novidades" e os links de versao/commit no menu do usuario.
# Sem isto o app nao busca release notes de lugar nenhum (o que e melhor do que
# exibir as de outro projeto).
GITHUB_REPO_OWNER=Bulletdev
GITHUB_REPO_NAME=muquirana

# ---------------------------------------------------------------------------
# OPCIONAIS
# ---------------------------------------------------------------------------

# Habilita o assistente de IA. Gera custo na SUA conta OpenAI -- configure
# limite de gasto antes de ativar. Sem isto, a tela de chat explica que falta a
# variavel, em vez de quebrar.
OPENAI_ACCESS_TOKEN=

# E-mail. Sem SMTP, reset de senha e convite nao chegam.
SMTP_ADDRESS=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_TLS_ENABLED=true
EMAIL_SENDER=

# ---------------------------------------------------------------------------
# NAO USE
# ---------------------------------------------------------------------------
# PLAID_CLIENT_ID / PLAID_SECRET: o Plaid cobre bancos dos EUA e da Europa.
# Nao atende banco brasileiro. A importacao de CSV e o caminho aqui.

# ================
# DEMO (opcional)
# ================
# URL da instancia de demonstracao. Com ela preenchida, a landing mostra o
# botao "Ver a demo"; sem ela, o botao some (nunca aponta para um 404).
#
# A demo e uma instancia SEPARADA, com banco proprio e nenhum dado real --
# nao aponte para esta mesma instalacao. Deixe VAZIA na instancia pessoal.
#
# Aponte para a rota /demo da outra instancia: ela loga o visitante como a
# conta publica de demonstracao e o joga direto no painel.
#   DEMO_URL=https://demo.muquirana.com/demo
DEMO_URL=

# ATENCAO: so na INSTANCIA DE DEMONSTRACAO. Nunca aqui.
#
# Com DEMO_INSTANCE=true a instancia:
#   1. expoe /demo, que cria sessao SEM SENHA como a conta de demo;
#   2. libera o `bin/rails demo:reset`, que APAGA TODAS AS FAMILIAS do banco.
#
# Nao ha uso legitimo disto numa instancia com dinheiro de verdade. Deixe
# vazia (ou ausente): so a string exata "true" liga.
DEMO_INSTANCE=
