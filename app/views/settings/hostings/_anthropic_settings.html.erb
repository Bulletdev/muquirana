<div class="space-y-4">
  <% env_key = ENV["ANTHROPIC_ACCESS_TOKEN"].presence || ENV["ANTHROPIC_API_KEY"].presence %>
  <% env_model = ENV["ANTHROPIC_MODEL"].presence %>

  <p class="text-secondary text-sm">
    <%= env_key.present? ? t(".env_var_configured") : t(".description") %>
  </p>

  <%= styled_form_with model: Setting.new,
                       url: settings_hosting_path,
                       method: :patch,
                       class: "space-y-4" do |form| %>
    <%= form.text_field :anthropic_access_token,
                        label: t(".access_token_label"),
                        type: "password",
                        placeholder: t(".access_token_placeholder"),
                        value: env_key || Setting.anthropic_access_token,
                        disabled: env_key.present? %>

    <% current_model = env_model || Setting.anthropic_model.presence || Provider::Anthropic::DEFAULT_MODEL %>
    <% model_choices = (Provider::Anthropic::MODELS | [ current_model ]).map { |m| [ m, m ] } %>
    <%= form.select :anthropic_model,
                    model_choices,
                    { label: t(".model_label"), selected: current_model },
                    { disabled: env_model.present? } %>

    <% unless env_key.present? && env_model.present? %>
      <div class="flex justify-end">
        <%= render DS::Button.new(text: t(".save"), variant: "primary", type: "submit") %>
      </div>
    <% end %>
  <% end %>
</div>
