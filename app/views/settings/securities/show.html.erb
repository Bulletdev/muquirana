<%= content_for :page_title, t(".page_title") %>

<% if @encryption_unconfigured %>
  <% encryption_warning = capture do %>
    <p class="font-medium"><%= t(".encryption_warning.title") %></p>
    <p class="mt-1"><%= t(".encryption_warning.intro") %></p>
    <ul class="list-disc pl-5 mt-1 space-y-0.5">
      <% t(".encryption_warning.keys").each do |key| %>
        <li><code><%= key %></code></li>
      <% end %>
    </ul>
    <p class="mt-1"><%= t(".encryption_warning.generate") %></p>
  <% end %>

  <div class="mb-4">
    <%= render DS::Alert.new(message: encryption_warning, variant: :warning) %>
  </div>
<% end %>

<%= settings_section title: t(".mfa_title"), subtitle: t(".mfa_description") do %>
  <div class="space-y-4">
    <div class="p-3 shadow-border-xs bg-container rounded-lg md:flex md:justify-between md:items-center">
      <div class="flex items-center gap-3">
        <div class="w-9 h-9 rounded-full bg-gray-25 flex justify-center items-center">
          <%= icon "shield-check" %>
        </div>

        <div class="text-sm space-y-1">
          <% if Current.user.otp_required? %>
            <p class="text-primary"><%= t(".mfa_status_html", status: tag.span(t(".status_enabled"), class: "font-medium text-green-600")) %></p>
            <p class="text-secondary"><%= t(".mfa_enabled_description") %></p>
          <% else %>
            <p class="text-primary"><%= t(".mfa_status_html", status: tag.span(t(".status_disabled"), class: "font-medium text-red-600")) %></p>
            <p class="text-secondary"><%= t(".mfa_disabled_description") %></p>
          <% end %>
        </div>
      </div>

      <div class="mt-4 md:mt-0">
        <% if Current.user.otp_required? %>
          <%= render DS::Button.new(
            text: t(".disable_mfa"),
            variant: "secondary",
            href: disable_mfa_path,
            method: :delete,
            confirm: CustomConfirm.new(
              title: t(".disable_mfa_confirm"),
              body: t(".disable_mfa_confirm"),
              btn_text: t(".disable_mfa"),
              destructive: true
            )
          ) %>
        <% else %>
          <%= render DS::Link.new(
            text: t(".enable_mfa"),
            variant: "primary",
            href: new_mfa_path
          ) %>
        <% end %>
      </div>
    </div>
  </div>
<% end %>
