<%# locals: (user:, placement: "right-start", offset: 16) %>

<div data-testid="user-menu">
  <%= render DS::Menu.new(variant: "avatar", avatar_url: user.profile_image&.variant(:small)&.url, initials: user.initials, placement: placement, offset: offset) do |menu| %>
    <%= menu.with_header do %>
      <div class="px-4 py-3 flex items-center gap-3">
        <div class="w-9 h-9 shrink-0">
          <%= render "settings/user_avatar", avatar_url: user.profile_image&.variant(:small)&.url, initials: user.initials, lazy: true %>
        </div>

        <div class="overflow-hidden text-ellipsis text-sm">
          <p class="font-medium"><%= user.display_name %></p>
          <% if user.display_name != user.email %>
            <p class="text-secondary"><%= user.email %></p>
          <% end %>
        </div>
      </div>

      <% if self_hosted? %>
        <% github = Provider::Github.new %>
        <% release_tag = Muquirana.version.to_release_tag %>
        <% release_url = github.release_url(release_tag) %>
        <div class="px-4 py-3 border-t border-tertiary">
          <p class="text-sm">
            <span class="font-medium text-primary"><%= t(".version") %></span>
            <%= release_url ? link_to(release_tag, release_url, target: "_blank", class: "hover:underline") : release_tag %>

            <% if Muquirana.commit_sha.present? %>
              <% commit_url = github.commit_url(Muquirana.commit_sha) %>
              (<%= commit_url ? link_to(Muquirana.commit_sha.first(7), commit_url, target: "_blank", class: "hover:underline") : Muquirana.commit_sha.first(7) %>)
            <% end %>
          </p>
        </div>
      <% end %>
    <% end %>

    <% menu.with_item(variant: "link", text: t(".settings"), icon: "settings", href: settings_profile_path(return_to: request.fullpath)) %>
    <% menu.with_item(variant: "link", text: t(".changelog"), icon: "box", href: changelog_path) %>

    <%# O ramo else abria o chat do Intercom (removido). Sem instancia
        gerenciada e sem Intercom, o Feedback vale para os dois modos. %>
    <% menu.with_item(variant: "link", text: t(".feedback"), icon: "megaphone", href: feedback_path) %>

    <% menu.with_item(variant: "divider") %>

    <% menu.with_item(variant: "button", text: t(".log_out"), icon: "log-out", href: session_path(Current.session), method: :delete) %>
  <% end %>
</div>
