<%= link_to t(".back"), rules_path %>

<%= render DS::Dialog.new do |dialog| %>
  <%
    resource_type = t("rules.resource_types.#{@rule.resource_type}", count: 1)

    title = if @rule.name.present?
              t(".title_named", resource_type: resource_type, name: @rule.name)
            else
              t(".title", resource_type: resource_type)
            end
  %>
  <% dialog.with_header(title: title) %>

  <% dialog.with_body do %>
    <%= render "rules/form", rule: @rule %>
  <% end %>
<% end %>
