<header class="flex items-center justify-between">
  <h1 class="text-primary text-xl font-medium"><%= t("recurring_transactions.title") %></h1>
  <div class="flex items-center gap-2">
    <% if @recurring_transactions.any? %>
      <%= render DS::Menu.new do |menu| %>
        <% menu.with_item(
          variant: "button",
          text: t("recurring_transactions.cleanup_stale"),
          href: cleanup_recurring_transactions_path,
          method: :post,
          icon: "trash-2") %>
      <% end %>
    <% end %>
    <%= render DS::Link.new(
      text: t("recurring_transactions.identify_patterns"),
      icon: "search",
      variant: "primary",
      href: identify_recurring_transactions_path,
      method: :post
    ) %>
  </div>
</header>

<div class="mt-4 space-y-4">
  <div class="p-4 bg-container-inset border border-secondary rounded-lg">
    <div class="flex items-start gap-2">
      <%= icon "info", class: "w-5 h-5 text-link mt-0.5 flex-shrink-0" %>
      <div>
        <p class="text-sm font-medium text-primary mb-2"><%= t("recurring_transactions.info.title") %></p>
        <p class="text-xs text-secondary mb-1"><%= t("recurring_transactions.info.description") %></p>
        <ul class="list-disc list-inside text-xs text-secondary space-y-0.5 ml-2">
          <% t("recurring_transactions.info.triggers").each do |trigger| %>
            <li><%= trigger %></li>
          <% end %>
        </ul>
      </div>
    </div>
  </div>

  <% if @recurring_transactions.empty? %>
    <div class="bg-container rounded-xl shadow-border-xs p-8 text-center">
      <%= icon "repeat", class: "w-8 h-8 text-secondary mx-auto mb-3" %>
      <p class="text-sm font-medium text-primary mb-1"><%= t("recurring_transactions.empty.title") %></p>
      <p class="text-sm text-secondary"><%= t("recurring_transactions.empty.description") %></p>
    </div>
  <% else %>
    <div class="bg-container rounded-xl shadow-border-xs overflow-x-auto">
      <table class="w-full">
        <thead>
          <tr class="text-xs uppercase font-medium text-secondary border-b border-primary">
            <th class="text-left py-3 px-4"><%= t("recurring_transactions.table.merchant") %></th>
            <th class="text-left py-3 px-4"><%= t("recurring_transactions.table.amount") %></th>
            <th class="text-left py-3 px-4"><%= t("recurring_transactions.table.expected_day") %></th>
            <th class="text-left py-3 px-4"><%= t("recurring_transactions.table.next_date") %></th>
            <th class="text-left py-3 px-4"><%= t("recurring_transactions.table.last_occurrence") %></th>
            <th class="text-left py-3 px-4"><%= t("recurring_transactions.table.status") %></th>
            <th class="text-right py-3 px-4"><%= t("recurring_transactions.table.actions") %></th>
          </tr>
        </thead>
        <tbody>
          <% @recurring_transactions.each do |recurring_transaction| %>
            <tr class="border-b border-alpha-black-100 theme-dark:border-alpha-white-100 hover:bg-surface-hover <%= "opacity-60" unless recurring_transaction.active? %>">
              <td class="py-3 px-4 text-sm">
                <div class="flex items-center gap-2">
                  <span class="text-primary font-medium">
                    <%= recurring_transaction.merchant&.name || recurring_transaction.name %>
                  </span>
                  <% if recurring_transaction.manual? %>
                    <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-blue-tint-10 text-link">
                      <%= t("recurring_transactions.badges.manual") %>
                    </span>
                  <% end %>
                </div>
              </td>
              <td class="py-3 px-4 text-sm font-medium privacy-sensitive <%= recurring_transaction.amount.negative? ? "text-success" : "text-primary" %>">
                <% if recurring_transaction.manual? && recurring_transaction.has_amount_variance? %>
                  <span title="<%= t("recurring_transactions.amount_range", min: format_money(recurring_transaction.expected_amount_min_money.abs), max: format_money(recurring_transaction.expected_amount_max_money.abs)) %>">
                    ~ <%= format_money(recurring_transaction.expected_amount_avg_money.abs) %>
                  </span>
                <% else %>
                  <%= format_money(recurring_transaction.amount_money.abs) %>
                <% end %>
              </td>
              <td class="py-3 px-4 text-sm text-secondary">
                <%= t("recurring_transactions.day_of_month", day: recurring_transaction.expected_day_of_month) %>
              </td>
              <td class="py-3 px-4 text-sm text-secondary">
                <%= recurring_transaction.next_expected_date.strftime("%d/%m/%Y") %>
              </td>
              <td class="py-3 px-4 text-sm text-secondary">
                <%= recurring_transaction.last_occurrence_date.strftime("%d/%m/%Y") %>
              </td>
              <td class="py-3 px-4 text-sm">
                <% if recurring_transaction.active? %>
                  <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-green-tint-10 text-success">
                    <%= t("recurring_transactions.status.active") %>
                  </span>
                <% else %>
                  <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-surface-inset text-primary">
                    <%= t("recurring_transactions.status.inactive") %>
                  </span>
                <% end %>
              </td>
              <td class="py-3 px-4 text-sm text-right">
                <div class="flex items-center justify-end gap-2">
                  <%= link_to toggle_status_recurring_transaction_path(recurring_transaction),
                      data: { turbo_method: :post },
                      class: "text-secondary hover:text-primary" do %>
                    <%= icon recurring_transaction.active? ? "pause" : "play", size: "sm" %>
                  <% end %>
                  <%= link_to recurring_transaction_path(recurring_transaction),
                      data: { turbo_method: :delete, turbo_confirm: t("recurring_transactions.confirm_delete") },
                      class: "text-secondary hover:text-destructive" do %>
                    <%= icon "trash-2", size: "sm" %>
                  <% end %>
                </div>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% end %>
</div>
