<%= render DS::Dialog.new do |dialog| %>
  <% dialog.with_header(title: t(".title")) %>
  <% dialog.with_body do %>
    <p class="text-sm text-secondary mb-4"><%= t(".description") %></p>

    <%= styled_form_with model: @ibkr_item, url: ibkr_items_path, class: "space-y-4" do |form| %>
      <% if @ibkr_item.errors.any? %>
        <div class="bg-warning-50 border border-warning-200 rounded-xl p-4 text-sm text-warning-800">
          <%= @ibkr_item.errors.full_messages.join(", ") %>
        </div>
      <% end %>

      <%= form.text_field :name,
            label: t(".name_label"),
            placeholder: t(".name_placeholder") %>

      <%= form.text_field :query_id,
            label: t(".query_id_label"),
            placeholder: t(".query_id_placeholder"),
            help_text: t(".query_id_help") %>

      <%= form.password_field :token,
            label: t(".token_label"),
            placeholder: t(".token_placeholder"),
            help_text: t(".token_help") %>

      <div class="bg-surface-inset rounded-xl p-4 text-sm text-secondary">
        <%= t(".flex_note") %>
      </div>

      <div class="flex justify-end gap-3 pt-4 border-t border-primary">
        <%= render DS::Button.new(
          text: t(".submit"),
          variant: "primary",
          type: "submit"
        ) %>
      </div>
    <% end %>
  <% end %>
<% end %>
