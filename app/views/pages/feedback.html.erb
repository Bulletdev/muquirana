<%= content_for :page_title, t(".page_title") %>

<%#
  Os tres cards apontavam para maybe-finance/maybe (discussions, issues) e para
  link.maybe.co/discord -- ou seja, mandavam o usuario deste fork para o
  repositorio e a comunidade do projeto original.

  Agora saem do repo configurado em GITHUB_REPO_OWNER/GITHUB_REPO_NAME, o mesmo
  que alimenta a tela "Novidades". Sem essa configuracao nao ha para onde
  mandar, e os cards de GitHub simplesmente nao aparecem -- melhor do que
  linkar o projeto de outra pessoa.
%>
<% repo_url = Provider::Github.new.repo_url %>

<div class="bg-container shadow-border-xs rounded-xl p-4">
  <h2 class="text-lg font-medium text-primary mb-1"><%= t(".title") %></h2>
  <p class="text-sm text-secondary mb-4"><%= t(".subtitle") %></p>
  <div class="flex flex-col md:flex-row gap-4">
    <% if repo_url %>
      <%= link_to "#{repo_url}/issues/new?labels=enhancement", target: "_blank", rel: "noopener noreferrer", class: "w-full md:w-1/3 flex flex-col items-center p-4 border border-alpha-black-25 rounded-xl hover:bg-container-hover" do %>
        <%= image_tag "github-icon.svg", class: "w-8 h-8 mb-2" %>
        <span class="text-sm font-medium text-primary text-center"><%= t(".feature_request") %></span>
      <% end %>
    <% end %>

    <% if self_hosted? %>
      <% if repo_url %>
        <%= link_to "#{repo_url}/issues/new?labels=bug", target: "_blank", rel: "noopener noreferrer", class: "w-full md:w-1/3 flex flex-col items-center p-4 border border-alpha-black-25 rounded-xl hover:bg-container-hover" do %>
          <%= image_tag "github-icon.svg", class: "w-8 h-8 mb-2" %>
          <span class="text-sm font-medium text-primary text-center"><%= t(".bug_report") %></span>
        <% end %>
      <% end %>
    <% else %>
      <%= tag.button class: "w-full md:w-1/3 flex flex-col gap-2 items-center p-4 border border-alpha-black-25 rounded-xl hover:bg-container-hover", data: { action: "intercom#show" } do %>
        <%= image_tag "github-icon.svg", class: "w-8 h-8 mb-2" %>
        <span class="text-sm font-medium text-primary text-center"><%= t(".bug_report") %></span>
      <% end %>
    <% end %>

    <%# Era o Discord do Maybe. Este fork nao tem servidor proprio, entao o card
        aponta para as Discussions do repositorio em vez de sumir. %>
    <% if repo_url %>
      <%= link_to "#{repo_url}/discussions", target: "_blank", rel: "noopener noreferrer", class: "w-full md:w-1/3 flex flex-col items-center p-4 border border-alpha-black-25 rounded-xl hover:bg-container-hover" do %>
        <%= image_tag "github-icon.svg", class: "w-8 h-8 mb-2" %>
        <span class="text-sm font-medium text-primary text-center"><%= t(".discussions") %></span>
      <% end %>
    <% end %>
  </div>
</div>
