<%= render DS::Dialog.new do |dialog| %>
  <% dialog.with_header(title: t(".title")) %>
  <% dialog.with_body do %>
    <p class="text-sm text-secondary mb-4"><%= t(".description") %></p>

    <%= styled_form_with model: @binance_item, url: binance_items_path, class: "space-y-4" do |form| %>
      <% if @binance_item.errors.any? %>
        <div class="bg-warning-50 border border-warning-200 rounded-xl p-4 text-sm text-warning-800">
          <%= @binance_item.errors.full_messages.join(", ") %>
        </div>
      <% end %>

      <%= form.text_field :name,
            label: t(".name_label"),
            placeholder: t(".name_placeholder") %>

      <%= form.text_field :api_key,
            label: t(".api_key_label"),
            placeholder: t(".api_key_placeholder"),
            help_text: t(".api_key_help") %>

      <%= form.password_field :api_secret,
            label: t(".api_secret_label"),
            placeholder: t(".api_secret_placeholder"),
            help_text: t(".api_secret_help") %>

      <div class="bg-surface-inset rounded-xl p-4 text-sm text-secondary">
        <%= t(".regulatory_note") %>
      </div>

      <div class="flex justify-end gap-3 pt-4 border-t border-primary">
        <%= render DS::Button.new(
          text: t(".submit"),
          variant: "primary",
          type: "submit"
        ) %>
      </div>
    <% end %>
  <% end %>
<% end %>
