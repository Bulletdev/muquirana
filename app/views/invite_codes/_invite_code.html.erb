<%#
  Mostra o LINK de convite, nao o codigo cru: o formulario de cadastro ja le
  ?invite=<token> e preenche o campo sozinho.

  O texto visivel e a propria URL de proposito: o clipboard_controller copia o
  textContent do alvo `source`, entao o que se ve e exatamente o que se copia.
  O `truncate` corta so na exibicao -- o textContent continua inteiro.

  bg-container-inset e text-primary, e nao bg-gray-25: os tokens gray-* sao
  literais fixos (#FAFAFA) que NAO acompanham o tema, e no escuro o texto
  branco sumia sobre esse fundo quase branco.

  Tres estados, e o link so aparece no primeiro:
    ativo    -> ainda ha vaga: copiar e revogar
    esgotado -> chegou no limite: nao ha o que copiar
    revogado -> voce desligou: fica no historico por causa de quem ja entrou
%>
<div class="invite_code pt-2">
  <div class="flex items-center justify-between gap-2 p-2 bg-container-inset rounded-md" data-controller="clipboard">
    <div class="min-w-0">
      <% if invite_code.available? %>
        <span data-clipboard-target="source"
              class="block text-sm font-medium truncate text-primary"
              title="<%= new_registration_url(invite: invite_code.token) %>"><%= new_registration_url(invite: invite_code.token) %></span>
      <% else %>
        <span class="block text-sm font-medium truncate text-secondary line-through">
          <%= new_registration_url(invite: invite_code.token) %>
        </span>
      <% end %>

      <p class="text-xs text-secondary mt-0.5">
        <%= t(".uses", usados: invite_code.uses_count, total: invite_code.max_uses) %>
        <% if invite_code.revoked? %>
          &middot; <%= t(".revoked_badge") %>
        <% elsif invite_code.exhausted? %>
          &middot; <%= t(".exhausted_badge") %>
        <% end %>
      </p>

      <%# Quem entrou. Era isto que nao existia quando o codigo era destruido no
          uso: o dono do servidor nao sabia quem tinha criado conta nele. %>
      <% if invite_code.users.any? %>
        <p class="text-xs text-secondary/80 truncate">
          <%= invite_code.users.map(&:email).join(", ") %>
        </p>
      <% end %>
    </div>

    <% if invite_code.available? %>
      <div class="flex items-center gap-1 shrink-0">
        <button data-action="clipboard#copy"
                class="z-10 inline-flex items-center px-1 text-sm text-secondary font-sm text-center"
                type="button"
                aria-label="<%= t(".copy_link") %>"
                title="<%= t(".copy_link") %>">
          <span data-clipboard-target="iconDefault">
            <%= icon "copy" %>
          </span>
          <span class="hidden inline-flex items-center" data-clipboard-target="iconSuccess">
            <%= icon "check" %>
          </span>
        </button>

        <%= button_to invite_code_path(invite_code),
              method: :delete,
              class: "z-10 inline-flex items-center px-1 text-sm text-secondary hover:text-destructive",
              "aria-label": t(".revoke"),
              title: t(".revoke"),
              data: { turbo_confirm: {
                title: t(".revoke_confirm.title"),
                body: t(".revoke_confirm.body"),
                confirmText: t(".revoke_confirm.accept"),
                variant: "destructive"
              } } do %>
          <%= icon "trash-2" %>
        <% end %>
      </div>
    <% end %>
  </div>
</div>
