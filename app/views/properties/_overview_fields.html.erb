<%# locals: (form:) %>

<div class="flex flex-col gap-2">
  <%= form.text_field :name,
                  label: t(".name"),
                  placeholder: t(".name_placeholder"),
                  required: true %>

  <%# Rotulo via Accountable#long_subtype_label_for, nao v[:long] direto: o mesmo
      subtipo aparece no badge da sidebar por esse metodo. Lendo o hash cru, o
      dropdown mostrava "Single Family Home" e a sidebar "Casa". %>
  <%= form.select :subtype,
                Property::SUBTYPES.keys.map { |k| [Property.long_subtype_label_for(k), k] },
                { prompt: t(".subtype_prompt"), label: t(".subtype") }, required: true %>

  <%= form.hidden_field :accountable_type, value: "Property" %>

  <%= form.fields_for :accountable do |property_form| %>
    <div class="flex items-center gap-2">
      <%= property_form.number_field :year_built,
                    label: t(".year_built"),
                    placeholder: t(".year_built_placeholder"),
                    min: 1800,
                    max: Time.current.year %>
    </div>

    <div class="flex items-center gap-2">
      <%= property_form.number_field :area_value,
                      label: t(".area"),
                      placeholder: t(".area_placeholder"),
                      min: 0 %>
      <%= property_form.select :area_unit,
                      [[t(".area_unit_sqft"), "sqft"], [t(".area_unit_sqm"), "sqm"]],
                      { label: t(".area_unit") } %>
    </div>
  <% end %>

</div>
