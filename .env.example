# ================================ PLEASE READ ===========================================================
# This file outlines all the possible environment variables supported by the Muquirana for self hosting.
#
# If you're a developer setting up your local environment, please use `.env.local.example` instead.
# ========================================================================================================

# Required self-hosting vars
# --------------------------------------------------------------------------------------------------------

# Enables self hosting features (should be set to true unless you know what you're doing)
SELF_HOSTED=true

# Secret key used to encrypt credentials (https://api.rubyonrails.org/v7.1.3.2/classes/Rails/Application.html#method-i-secret_key_base)
# Has to be a random string, generated eg. by running `openssl rand -hex 64`
SECRET_KEY_BASE=secret-value

# Optional self-hosting vars
# --------------------------------------------------------------------------------------------------------

# Optional: Synth API Key for exchange rates + stock prices
# (you can also set this in your self-hosted settings page)
# Get it here: https://synthfinance.com/
SYNTH_API_KEY=

# Custom port config
# For users who have other applications listening at 3000, this allows them to set a value puma will listen to.
PORT=3000

# SMTP Configuration
# This is only needed if you intend on sending emails from your instância do Muquirana (such as for password resets or email financial reports).
# Resend.com is a good option that offers a free tier for sending emails.
SMTP_ADDRESS=
SMTP_PORT=465
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_TLS_ENABLED=true

# Address that emails are sent from
EMAIL_SENDER=

# Database Configuration
DB_HOST=localhost # May need to be changed to `DB_HOST=db` if using devcontainer
DB_PORT=5432
POSTGRES_PASSWORD=postgres
POSTGRES_USER=postgres

# App Domain
# This is the domain that your instância do Muquirana will be hosted at. It is used to generate links in emails and other places.
APP_DOMAIN=

# AGPLv3 secao 13: usuarios que acessam o app pela rede tem direito ao
# codigo-fonte correspondente. Aponte para o repositorio desta instancia --
# incluindo suas modificacoes, se voce alterou o codigo. Sem isso, o link do
# rodape nao e renderizado e a instancia fica fora de conformidade.
SOURCE_CODE_URL=

# Disable enforcing SSL connections
# DISABLE_SSL=true

# Chaves de criptografia do Active Record (RECOMENDADO para self-hosting)
# ---------------------------------------------------------------------------
# Protegem dados sensiveis no banco: chaves de API, tokens dos providers de
# cripto (Binance/Coinbase/etc.), segredo do 2FA e demais campos criptografados.
#
# Se NAO forem definidas, o app as deriva do SECRET_KEY_BASE e funciona -- mas a
# tela Configuracoes > Seguranca exibe um aviso, porque girar o SECRET_KEY_BASE
# sem antes fixar chaves explicitas torna TODOS esses dados ilegiveis de forma
# permanente. Defina-as ANTES de por dados reais.
#
# ATENCAO: so defina isto em instancia NOVA (sem dados) ou desde o inicio. Se a
# instancia JA tem dados cifrados (gravados com as chaves derivadas do
# SECRET_KEY_BASE), adicionar chaves explicitas DEPOIS quebra a descriptografia
# (Decryption error -> 500). Nesse caso, REMOVA estas 3 variaveis e faca redeploy:
# o app volta a derivar do SECRET_KEY_BASE e os dados reabrem (desde que o
# SECRET_KEY_BASE nao tenha mudado). Migrar com dados exige configurar a chave
# antiga como `previous` e re-encriptar.
#
# Gere um conjunto com:  bin/rails db:encryption:init
# e cole os valores abaixo (mantenha-os em segredo, nunca versione).
# ACTIVE_RECORD_ENCRYPTION_PRIMARY_KEY=
# ACTIVE_RECORD_ENCRYPTION_DETERMINISTIC_KEY=
# ACTIVE_RECORD_ENCRYPTION_KEY_DERIVATION_SALT=

# ======================================================================================================
# Active Storage Configuration - responsible for storing file uploads
# ======================================================================================================
#
# * Defaults to disk storage but you can also use Amazon S3 or Cloudflare R2
# * Set the appropriate environment variables to use these services.
# * Ensure libvips is installed on your system for image processing - https://github.com/libvips/libvips
#
# Amazon S3
# ==========
# ACTIVE_STORAGE_SERVICE=amazon <- Enables Amazon S3 storage
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_REGION= # defaults to `us-east-1` if not set
# S3_BUCKET=
#
# Cloudflare R2
# =============
# ACTIVE_STORAGE_SERVICE=cloudflare <- Enables Cloudflare R2 storage
# CLOUDFLARE_ACCOUNT_ID=
# CLOUDFLARE_ACCESS_KEY_ID=
# CLOUDFLARE_SECRET_ACCESS_KEY=
# CLOUDFLARE_BUCKET=
#

# Tela "Novidades" (/changelog): busca as notas da ultima release deste
# repositorio no GitHub. Sem estas variaveis nenhuma chamada e feita e a tela
# mostra o estado vazio. Antes o repositorio era fixo no projeto original, o que
# exibia as notas de versao DELES como se fossem deste app.
GITHUB_REPO_OWNER=
GITHUB_REPO_NAME=

# Sidekiq e Action Cable. No compose, aponta para o servico redis da rede.
REDIS_URL=redis://localhost:6379/1

# Habilita o assistente de IA. Gera custo na SUA conta OpenAI -- configure
# limite de gasto antes de ativar.
OPENAI_ACCESS_TOKEN=

# US-07: alternativa ao OpenAI usando Anthropic (Claude). Gera custo na SUA conta
# Anthropic -- configure limite de gasto antes de ativar. Tambem configuravel em
# Configuracoes > Hospedagem propria; a ENV tem prioridade.
ANTHROPIC_ACCESS_TOKEN=
# Modelo Anthropic (ex.: claude-sonnet-5). Em branco usa o default do provider.
ANTHROPIC_MODEL=

# US-08: Assistente externo self-hosted. Aponte o assistente para um LLM local
# seu (Ollama, LM Studio ou agente proprio) para que os dados nao saiam da
# maquina. Basta a URL para ativar; deixe em branco para usar a OpenAI.
# Protocolo: /v1/chat/completions compativel com OpenAI (SSE). O nativo do
# Ollama (/api/chat) NAO e suportado -- use a porta OpenAI-compat. So o host ja
# basta: http://localhost:11434 vira .../v1/chat/completions automaticamente.
# Tambem configuravel em Configuracoes > Hospedagem propria. A ENV tem prioridade.
EXTERNAL_ASSISTANT_URL=
# Modelo disponivel no endpoint (ex.: llama3.2). Obrigatorio no Ollama.
EXTERNAL_ASSISTANT_MODEL=
# Token opcional (Bearer). Ollama local nao exige; LM Studio idem.
EXTERNAL_ASSISTANT_TOKEN=
# Opcionais, para um agente proprio (viram headers X-Agent-Id / X-Session-Key).
EXTERNAL_ASSISTANT_AGENT_ID=
EXTERNAL_ASSISTANT_SESSION_KEY=

# Atras de proxy com TLS (Traefik/Coolify), ligue os dois. ASSUME_SSL faz o
# Rails confiar no X-Forwarded-Proto; sem ele, o FORCE_SSL redireciona em loop.
RAILS_FORCE_SSL=false
RAILS_ASSUME_SSL=false
