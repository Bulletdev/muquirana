# Template de desenvolvimento local. Copie para .env.local:
#   cp .env.local.example .env.local
# O .env.local e gitignored. Os valores abaixo ja batem com o compose.dev.yml,
# entao `bin/dev` funciona sem editar nada.

# Modo self-hosted: desliga o paywall/Stripe. Deixe true no dev.
SELF_HOSTED=true

# Porta do servidor web.
PORT=3000

# --- Postgres (container `muquirana-pg` do compose.dev.yml) -----------------
# Porta 5434 de proposito, para nao colidir com um Postgres em 5432 de outro
# projeto. Se rodar Postgres proprio, ajuste host/porta/credenciais aqui.
DB_HOST=127.0.0.1
DB_PORT=5434
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# --- Redis (container `muquirana-redis` do compose.dev.yml) -----------------
# Porta 6380 de proposito, para nao colidir com um Redis em 6379.
REDIS_URL=redis://localhost:6380

# --- Demonstracao ----------------------------------------------------------
# Liga a rota /demo (login sem senha). Na primeira vez, `bin/dev` popula os
# dados de teste automaticamente: login user@muquirana.local / password.
# NUNCA ligue numa instancia com dado real.
DEMO_INSTANCE=true
DEMO_URL=http://localhost:3000/demo

# --- Links do rodape / changelog (AGPLv3 secao 13) -------------------------
# Aponte para o SEU fork ao publicar uma instancia.
SOURCE_CODE_URL=https://github.com/Bulletdev/muquirana
GITHUB_REPO_OWNER=Bulletdev
GITHUB_REPO_NAME=muquirana
